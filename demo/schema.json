{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Checkpoint Gate Roadmap",
  "description": "Schema for checkpoint-gate-roadmaps fixture files.",
  "type": "object",
  "required": ["checkpoints"],
  "properties": {
    "roadmap_name": {
      "type": "string",
      "description": "Display name for the audit report."
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "name"],
        "properties": {
          "key": {
            "type": "string",
            "description": "Stable identifier (e.g. CP1, MVP3, STAGE5)."
          },
          "name": {
            "type": "string",
            "description": "Short human label."
          },
          "done_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "found"],
              "properties": {
                "label": { "type": "string" },
                "found": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          },
          "gate": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "passed"],
              "properties": {
                "label": { "type": "string" },
                "passed": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
